# Copy to .env and fill values. Never commit .env.

# MySQL (shared hosting: use cPanel MySQL user/host/port)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=   # XAMPP default root password empty থাকে
DB_NAME=medicinestore

# First-time DB: copy this file to .env, then run:
#   npm run db:setup
# That imports database/schema.sql (recreates tables) and seeds admin + demo products.

# Server
PORT=3000
NODE_ENV=development

# JWT secret for admin (use long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# HTTPS / reverse proxy (set to 1 behind nginx/cPanel SSL termination)
TRUST_PROXY=0

# Public site URL (for SEO canonicals if you add them; optional)
PUBLIC_URL=http://localhost:3000

# WhatsApp business number (country code without +, e.g. 8801XXXXXXXXX)
WHATSAPP_NUMBER=8801403407381

# Optional: notify customer on order status change (requires guest_email on order)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Online Medicine Store <noreply@example.com>"
